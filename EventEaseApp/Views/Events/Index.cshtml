@model IEnumerable<EventEaseApp.Models.Event>

@{
    ViewData["Title"] = "Events";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Events", null) };
}

<partial name="_Breadcrumb" />

<div class="page-header">
    <h1 class="page-title">Events</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-eventease-primary">Add New Event</a>
    }
</div>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var ev in Model)
        {
            <div class="col-md-4">
                <div class="card card-eventease h-100">
                    @if (!string.IsNullOrEmpty(ev.ImageUrl))
                    {
                        <img src="@ev.ImageUrl" class="card-img-top" alt="@ev.EventName" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=600" class="card-img-top" alt="Event placeholder" style="height: 200px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title fw-semibold">@ev.EventName</h5>
                        <p class="card-text text-muted small">@ev.EventDate.ToString("dd MMM yyyy")</p>
                        @if (ev.EventType != null)
                        {
                            <span class="badge bg-info mb-2">@ev.EventType.Name</span>
                        }
                        @if (ev.Venue != null)
                        {
                            <p class="card-text small mb-1"><strong>Venue:</strong> @ev.Venue.VenueName</p>
                        }
                        @if (!string.IsNullOrEmpty(ev.Description))
                        {
                            <p class="card-text small text-muted">@(ev.Description!.Length > 80 ? ev.Description.Substring(0, 80) + "..." : ev.Description)</p>
                        }
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2 flex-wrap">
                        <a asp-action="Details" asp-route-id="@ev.EventId" class="btn btn-sm btn-outline-eventease">Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@ev.EventId" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@ev.EventId" class="btn btn-sm btn-outline-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    ViewData["EmptyStateTitle"] = "No events yet";
    ViewData["EmptyStateMessage"] = User.IsInRole("Admin") ? "Get started by adding your first event." : "Check back soon for upcoming events.";
    if (User.IsInRole("Admin"))
    {
        ViewData["EmptyStateActionText"] = "Add Event";
        ViewData["EmptyStateActionUrl"] = Url.Action("Create");
    }
    <partial name="_EmptyState" />
}
