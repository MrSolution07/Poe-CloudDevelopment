@model EventEaseApp.Models.Event

@{
    ViewData["Title"] = "Edit Event";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Events", Url.Action("Index")), ("Edit", null) };
}

<partial name="_Breadcrumb" />

<h2 class="page-title mb-4">Edit Event</h2>

<div class="form-card">
    <form asp-action="Edit" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="EventId" />

        <div class="form-section-title">Basic Information</div>
        <div class="mb-3">
            <label asp-for="EventName" class="form-label"></label>
            <input asp-for="EventName" class="form-control" />
            <span asp-validation-for="EventName" class="text-danger"></span>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="EventDate" class="form-label"></label>
                <input asp-for="EventDate" class="form-control" type="datetime-local" />
                <span asp-validation-for="EventDate" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="EventTypeId" class="form-label">Event Type</label>
                <select asp-for="EventTypeId" asp-items="@ViewBag.EventTypeId" class="form-select">
                    <option value="">-- Select Event Type --</option>
                </select>
            </div>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
        <div class="mb-3">
            <label asp-for="VenueId" class="form-label">Venue</label>
            <select asp-for="VenueId" asp-items="@ViewBag.VenueId" class="form-select">
                <option value="">-- Select Venue (optional) --</option>
            </select>
        </div>

        <div class="form-section-title mt-4">Image</div>
        <div class="mb-3">
            <label asp-for="ImageUrl" class="form-label">Image URL</label>
            <input asp-for="ImageUrl" class="form-control" />
        </div>
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="mb-3">
                <img src="@Model.ImageUrl" alt="Current" class="img-thumbnail" style="max-height: 150px;" />
            </div>
        }
        <div class="mb-4">
            <label class="form-label">Upload New Image</label>
            <input type="file" name="imageFile" class="form-control" accept="image/*" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-eventease-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
