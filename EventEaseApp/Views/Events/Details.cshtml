@model EventEaseApp.Models.Event

@{
    ViewData["Title"] = "Event Details";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Events", Url.Action("Index")), (Model.EventName, null) };
}

<partial name="_Breadcrumb" />

<div class="card card-eventease">
    <div class="row g-0">
        <div class="col-md-5">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.EventName" class="img-fluid rounded-start" style="height: 100%; object-fit: cover;" />
            }
            else
            {
                <div class="img-placeholder rounded-start" style="height: 250px;">&#128197;</div>
            }
        </div>
        <div class="col-md-7">
            <div class="card-body p-4">
                <h2 class="card-title fw-semibold mb-3">@Model.EventName</h2>
                @if (Model.EventType != null)
                {
                    <span class="badge bg-info mb-3">@Model.EventType.Name</span>
                }
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(m => m.EventDate)</dt>
                    <dd class="col-sm-8">@Model.EventDate.ToString("dd MMM yyyy HH:mm")</dd>

                    <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(m => m.Description)</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "N/A")</dd>

                    <dt class="col-sm-4 text-muted">Venue</dt>
                    <dd class="col-sm-8">@(Model.Venue?.VenueName ?? "Not assigned")</dd>
                </dl>
                <div class="mt-4 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-outline-warning">Edit</a>
                    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
