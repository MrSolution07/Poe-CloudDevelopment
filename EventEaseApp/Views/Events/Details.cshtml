@model EventEaseApp.Models.Event

@{
    ViewData["Title"] = "Event Details";
}

<h2>Event Details</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.EventName" class="img-fluid rounded mb-3" style="max-height: 300px;" />
        }
        <dl class="row">
            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.EventName)</dt>
            <dd class="col-sm-8">@Model.EventName</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.EventDate)</dt>
            <dd class="col-sm-8">@Model.EventDate.ToString("dd MMM yyyy HH:mm")</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Description)</dt>
            <dd class="col-sm-8">@(Model.Description ?? "N/A")</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.EventType)</dt>
            <dd class="col-sm-8">@(Model.EventType?.Name ?? "N/A")</dd>

            <dt class="col-sm-4">Venue</dt>
            <dd class="col-sm-8">@(Model.Venue?.VenueName ?? "Not assigned")</dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
