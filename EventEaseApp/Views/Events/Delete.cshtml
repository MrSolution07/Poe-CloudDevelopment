@model EventEaseApp.Models.Event

@{
    ViewData["Title"] = "Delete Event";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Events", Url.Action("Index")), ("Delete", null) };
}

<partial name="_Breadcrumb" />

<div class="delete-warning mb-4">
    <h2 class="h4 fw-semibold text-danger mb-3">Delete Event</h2>
    <p class="mb-0">Are you sure you want to delete this event? This action cannot be undone. Events with active bookings cannot be deleted.</p>
</div>

<div class="form-card">
    <dl class="row mb-0">
        <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(m => m.EventName)</dt>
        <dd class="col-sm-9">@Model.EventName</dd>

        <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(m => m.EventDate)</dt>
        <dd class="col-sm-9">@Model.EventDate.ToString("dd MMM yyyy HH:mm")</dd>

        <dt class="col-sm-3 text-muted">Venue</dt>
        <dd class="col-sm-9">@(Model.Venue?.VenueName ?? "Not assigned")</dd>

        <dt class="col-sm-3 text-muted">Event Type</dt>
        <dd class="col-sm-9">@(Model.EventType?.Name ?? "N/A")</dd>
    </dl>

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="EventId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
