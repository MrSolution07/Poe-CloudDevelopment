@model IEnumerable<EventEaseApp.Models.Venue>

@{
    ViewData["Title"] = "Venues";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Venues", null) };
}

<partial name="_Breadcrumb" />

<div class="page-header">
    <h1 class="page-title">Venues</h1>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Create" class="btn btn-eventease-primary">Add New Venue</a>
    }
</div>

@if (Model.Any())
{
    <div class="row g-4">
        @foreach (var venue in Model)
        {
            <div class="col-md-4">
                <div class="card card-eventease h-100">
                    @if (!string.IsNullOrEmpty(venue.ImageUrl))
                    {
                        <img src="@venue.ImageUrl" class="card-img-top" alt="@venue.VenueName" style="height: 200px; object-fit: cover;" />
                    }
                    else
                    {
                        <img src="https://images.unsplash.com/photo-1519167758481-83f550bb49b3?w=600" class="card-img-top" alt="Venue placeholder" style="height: 200px; object-fit: cover;" />
                    }
                    <div class="card-body">
                        <h5 class="card-title fw-semibold">@venue.VenueName</h5>
                        <p class="card-text text-muted small">@venue.Location</p>
                        <p class="card-text mb-2">
                            <strong>Capacity:</strong> @venue.Capacity
                            <span class="badge @(venue.IsAvailable ? "badge-eventease-available" : "badge-eventease-unavailable") ms-2">
                                @(venue.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </p>
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2 flex-wrap">
                        <a asp-action="Details" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-eventease">Details</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@venue.VenueId" class="btn btn-sm btn-outline-danger">Delete</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    ViewData["EmptyStateTitle"] = "No venues yet";
    ViewData["EmptyStateMessage"] = User.IsInRole("Admin") ? "Get started by adding your first venue." : "Check back soon for available venues.";
    if (User.IsInRole("Admin"))
    {
        ViewData["EmptyStateActionText"] = "Add Venue";
        ViewData["EmptyStateActionUrl"] = Url.Action("Create");
    }
    <partial name="_EmptyState" />
}
