@model EventEaseApp.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<h2>Venue Details</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.VenueName" class="img-fluid rounded mb-3" style="max-height: 300px;" />
        }
        <dl class="row">
            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.VenueName)</dt>
            <dd class="col-sm-8">@Model.VenueName</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Location)</dt>
            <dd class="col-sm-8">@Model.Location</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Capacity)</dt>
            <dd class="col-sm-8">@Model.Capacity</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.IsAvailable)</dt>
            <dd class="col-sm-8">
                <span class="badge @(Model.IsAvailable ? "bg-success" : "bg-secondary")">
                    @(Model.IsAvailable ? "Available" : "Unavailable")
                </span>
            </dd>
        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
