@model EventEaseApp.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<h2>Delete Venue</h2>
<h4 class="text-danger">Are you sure you want to delete this venue?</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.VenueName)</dt>
            <dd class="col-sm-8">@Model.VenueName</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Location)</dt>
            <dd class="col-sm-8">@Model.Location</dd>

            <dt class="col-sm-4">@Html.DisplayNameFor(m => m.Capacity)</dt>
            <dd class="col-sm-8">@Model.Capacity</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="VenueId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>
