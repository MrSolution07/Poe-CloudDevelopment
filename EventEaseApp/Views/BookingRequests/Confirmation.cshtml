@{
    ViewData["Title"] = "Request Submitted";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-6 text-center">
        <div class="form-card p-5">
            <img src="https://images.unsplash.com/photo-1540575467063-178a50c2df87?w=400" alt="Event" class="rounded mb-4" style="max-height: 180px; object-fit: cover; width: 100%;" />
            <h2 class="fw-semibold mb-3">Request Submitted</h2>
            <p class="text-muted mb-4">Thank you for your booking enquiry. One of our booking specialists will review your request and contact you shortly.</p>
            <div class="d-flex gap-2 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-eventease-primary">Back to Home</a>
                <a asp-controller="Venues" asp-action="Index" class="btn btn-outline-eventease">Browse Venues</a>
            </div>
        </div>
    </div>
</div>
