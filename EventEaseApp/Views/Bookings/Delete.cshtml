@model EventEaseApp.Models.Booking

@{
    ViewData["Title"] = "Delete Booking";
}

<h2>Delete Booking</h2>
<h4 class="text-danger">Are you sure you want to delete this booking?</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row">
            <dt class="col-sm-4">Booking ID</dt>
            <dd class="col-sm-8">@Model.BookingId</dd>

            <dt class="col-sm-4">Event</dt>
            <dd class="col-sm-8">@Model.Event?.EventName</dd>

            <dt class="col-sm-4">Venue</dt>
            <dd class="col-sm-8">@Model.Venue?.VenueName</dd>

            <dt class="col-sm-4">Booking Date</dt>
            <dd class="col-sm-8">@Model.BookingDate.ToString("dd MMM yyyy")</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="BookingId" />
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
    </div>
</div>
