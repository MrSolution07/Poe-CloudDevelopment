@model EventEaseApp.Models.Booking

@{
    ViewData["Title"] = "Booking Details";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Bookings", Url.Action("Index")), ("Booking #" + Model.BookingId, null) };
}

<partial name="_Breadcrumb" />

<div class="form-card">
    <h2 class="h4 fw-semibold mb-4">Booking #@Model.BookingId</h2>
    <dl class="row mb-0">
        <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(m => m.BookingId)</dt>
        <dd class="col-sm-9">@Model.BookingId</dd>

        <dt class="col-sm-3 text-muted">Event</dt>
        <dd class="col-sm-9">@Model.Event?.EventName</dd>

        <dt class="col-sm-3 text-muted">Venue</dt>
        <dd class="col-sm-9">@Model.Venue?.VenueName</dd>

        <dt class="col-sm-3 text-muted">@Html.DisplayNameFor(m => m.BookingDate)</dt>
        <dd class="col-sm-9">@Model.BookingDate.ToString("dd MMM yyyy")</dd>
    </dl>

    <div class="mt-4 d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.BookingId" class="btn btn-outline-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
