@model EventEaseApp.Models.BookingSearchViewModel

@{
    ViewData["Title"] = "Booking Overview";
}

<h2>Booking Overview</h2>
<p class="text-muted">Search and filter bookings across all venues and events.</p>
<hr />

<form asp-action="Overview" method="get" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Search (Booking ID or Event Name)</label>
            <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control"
                   placeholder="e.g. 1 or Tech Summit" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Event Type</label>
            <select name="EventTypeId" class="form-select">
                <option value="">All Types</option>
                @foreach (var et in Model.EventTypes)
                {
                    <option value="@et.EventTypeId"
                            selected="@(Model.EventTypeId == et.EventTypeId)">@et.Name</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label">Date From</label>
            <input type="date" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Date To</label>
            <input type="date" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
        </div>
        <div class="col-md-2">
            <label class="form-label">Venue Availability</label>
            <select name="IsAvailable" class="form-select">
                <option value="">All</option>
                <option value="true" selected="@(Model.IsAvailable == true)">Available</option>
                <option value="false" selected="@(Model.IsAvailable == false)">Unavailable</option>
            </select>
        </div>
        <div class="col-md-1">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </div>
</form>

@if (Model.Results.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Booking ID</th>
                <th>Event</th>
                <th>Event Type</th>
                <th>Event Date</th>
                <th>Venue</th>
                <th>Location</th>
                <th>Capacity</th>
                <th>Availability</th>
                <th>Booking Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Results)
            {
                <tr>
                    <td>@item.BookingId</td>
                    <td>@item.EventName</td>
                    <td>@(item.EventTypeName ?? "N/A")</td>
                    <td>@item.EventDate.ToString("dd MMM yyyy")</td>
                    <td>@item.VenueName</td>
                    <td>@item.Location</td>
                    <td>@item.Capacity</td>
                    <td>
                        <span class="badge @(item.IsAvailable ? "bg-success" : "bg-secondary")">
                            @(item.IsAvailable ? "Available" : "Unavailable")
                        </span>
                    </td>
                    <td>@item.BookingDate.ToString("dd MMM yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
    <p class="text-muted">Total results: @Model.Results.Count</p>
}
else
{
    <div class="alert alert-info">No bookings found matching your criteria.</div>
}
