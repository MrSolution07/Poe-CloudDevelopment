@model EventEaseApp.Models.BookingSearchViewModel

@{
    ViewData["Title"] = "Booking Overview";
    ViewData["Breadcrumbs"] = new List<(string, string?)> { ("Home", Url.Action("Index", "Home")), ("Bookings", Url.Action("Index")), ("Overview", null) };
}

<partial name="_Breadcrumb" />

<div class="page-header">
    <h1 class="page-title">Booking Overview</h1>
</div>

<p class="text-muted mb-4">Search and filter bookings across all venues and events.</p>

<div class="card card-eventease mb-4">
    <div class="card-body p-4">
        <form asp-action="Overview" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search (Booking ID or Event Name)</label>
                    <input type="text" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="e.g. 1 or Tech Summit" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Event Type</label>
                    <select name="EventTypeId" class="form-select">
                        <option value="">All Types</option>
                        @foreach (var et in Model.EventTypes)
                        {
                            @if (Model.EventTypeId == et.EventTypeId)
                            {
                                <option value="@et.EventTypeId" selected>@et.Name</option>
                            }
                            else
                            {
                                <option value="@et.EventTypeId">@et.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Date From</label>
                    <input type="date" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Date To</label>
                    <input type="date" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Venue Availability</label>
                    <select name="IsAvailable" class="form-select">
                        <option value="">All</option>
                        @if (Model.IsAvailable == true)
                        {
                            <option value="true" selected>Available</option>
                            <option value="false">Unavailable</option>
                        }
                        else if (Model.IsAvailable == false)
                        {
                            <option value="true">Available</option>
                            <option value="false" selected>Unavailable</option>
                        }
                        else
                        {
                            <option value="true">Available</option>
                            <option value="false">Unavailable</option>
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-eventease-primary w-100">Search</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Results.Any())
{
    <div class="table-responsive-card">
        <table class="table table-eventease table-striped mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th></th>
                    <th>Event</th>
                    <th>Event Type</th>
                    <th>Event Date</th>
                    <th>Venue</th>
                    <th>Location</th>
                    <th>Capacity</th>
                    <th>Availability</th>
                    <th>Booking Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Results)
                {
                    <tr>
                        <td><strong>@item.BookingId</strong></td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.EventImageUrl))
                            {
                                <img src="@item.EventImageUrl" alt="@item.EventName" class="overview-thumb" />
                            }
                            else if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.VenueName" class="overview-thumb" />
                            }
                            else
                            {
                                <div class="overview-thumb-placeholder">&#128197;</div>
                            }
                        </td>
                        <td>@item.EventName</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.EventTypeName))
                            {
                                <span class="badge bg-info">@item.EventTypeName</span>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </td>
                        <td>@item.EventDate.ToString("dd MMM yyyy")</td>
                        <td>@item.VenueName</td>
                        <td class="text-muted small">@item.Location</td>
                        <td>@item.Capacity</td>
                        <td>
                            <span class="badge @(item.IsAvailable ? "badge-eventease-available" : "badge-eventease-unavailable")">
                                @(item.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </td>
                        <td>@item.BookingDate.ToString("dd MMM yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted mt-3 mb-0"><strong>Total results:</strong> @Model.Results.Count</p>
}
else
{
    ViewData["EmptyStateTitle"] = "No bookings found";
    ViewData["EmptyStateMessage"] = "Try adjusting your search or filter criteria.";
    <partial name="_EmptyState" />
}
